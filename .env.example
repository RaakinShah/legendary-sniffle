# Copy this file to .env and fill in your values.

# Get a key at https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# ASSISTANT_NAME=Aide
# ASSISTANT_MODEL=claude-opus-4-8
# Where the assistant keeps its memory, tasks, and briefings:
# ASSISTANT_HOME=~/.assistant
# Extra directories (colon-separated) the assistant may read/write,
# e.g. your documents folder. By default it can only touch ASSISTANT_HOME.
# ASSISTANT_ALLOWED_DIRS=~/Documents:~/Projects
