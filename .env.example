# Copy this file to .env and fill in ONE of the two auth options below.

# Option A — Claude Pro/Max subscription (no API credits needed):
# run `claude setup-token` after installing Claude Code, paste the result here.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Option B — API key from https://console.anthropic.com -> API Keys
# ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# ASSISTANT_NAME=Aide
# ASSISTANT_MODEL=claude-opus-4-8
# Where the assistant keeps its memory, tasks, and briefings:
# ASSISTANT_HOME=~/.assistant
# Full system access (default on): assistant can act across your home directory
# without per-action approval. Set to 0 to sandbox it to ASSISTANT_HOME +
# ASSISTANT_ALLOWED_DIRS with edit confirmation.
# ASSISTANT_FULL_ACCESS=1
# Extra directories (colon-separated) when not in full-access mode:
# ASSISTANT_ALLOWED_DIRS=~/Documents:~/Projects
