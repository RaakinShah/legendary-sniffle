# Copy this file to .env. The default backend is Claude (claude-haiku-4-5), so the
# only thing Aide needs is Claude credentials — and a stored `claude` login on this
# machine already counts, in which case .env can stay empty.

# --- Claude auth (default backend; also powers the advisor in local mode) ----
# Option A — Claude Pro/Max subscription (no API credits needed):
# run `claude setup-token` after installing Claude Code, paste the result here.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...
#
# Option B — API key from https://console.anthropic.com -> API Keys
# ANTHROPIC_API_KEY=sk-ant-...

# --- Backend: which brain runs every turn -----------------------------------
# "claude" (default) = the Claude Agent SDK on ASSISTANT_MODEL below; accurate,
#                      no local RAM, needs internet + the credentials above.
# "ollama"           = a local model: free, private, offline — but a small local
#                      model is far more prone to making things up.
# "apple"            = Apple's on-device Foundation model (macOS 26+, Apple
#                      Intelligence on). OS-managed weights (nothing heavy loads
#                      into Aide), free/private/offline, fastest to spin up. It's
#                      a ~3B model: lighter than Claude and more error-prone, so
#                      it runs a curated toolset + a compact prompt, and it can
#                      escalate a hard turn to Claude via think_harder. Install
#                      with: pip install apple-fm-sdk    (or `pip install .[apple]`)
# ASSISTANT_BACKEND=claude
# Apple Private Cloud Compute: a much stronger Apple model (reasoning levels, 32K
# context), still free/private/key-less. The Python SDK can't reach it, so Aide
# uses a native Swift bridge (build it once with: bridge/build.sh). With
# ASSISTANT_APPLE_CLOUD=1 and the bridge built, the apple backend runs through it
# — on the on-device model today, and on Private Cloud Compute automatically once
# the bridge is rebuilt against the macOS 27 SDK (Xcode 27). Without the bridge
# built, this falls back to the in-process on-device engine.
# ASSISTANT_APPLE_CLOUD=0

# --- Claude backend settings --------------------------------------------------
# ASSISTANT_MODEL=claude-haiku-4-5     # the default brain
# ASSISTANT_EFFORT=high                # reasoning depth: high = sweet spot; xhigh = max

# --- Escalation: a stronger brain on demand -----------------------------------
# Haiku runs every turn; hard turns call the `think_harder` tool to consult a
# stronger model, and a turn that errors is retried once on it. The weekly
# memory-consolidation job also runs on the escalation model.
# ASSISTANT_ESCALATE=1
# ASSISTANT_ESCALATE_MODEL=claude-sonnet-4-6      # think_harder default + auto-retry
# ASSISTANT_ESCALATE_MODEL_MAX=claude-opus-4-8    # think_harder level="opus"
# ASSISTANT_ESCALATE_EFFORT=high

# --- Local (Ollama) settings (only used when ASSISTANT_BACKEND=ollama) --------
# OLLAMA_HOST=http://localhost:11434
# ASSISTANT_OLLAMA_MODEL=llama3.1:8b   # ~4.9GB, fits 16GB RAM; must support tools.
#                                      # Bigger (gpt-oss:20b ~13GB) can freeze a 16GB Mac.
# ASSISTANT_OLLAMA_NUM_CTX=8192        # context window; bigger = more RAM used.
# ASSISTANT_OLLAMA_KEEP_ALIVE=5m       # how long the model stays resident after a turn
#                                      # ("0" unloads immediately to free RAM).
# ASSISTANT_OLLAMA_MAX_STEPS=12        # hard cap on tool rounds in one turn.

# --- Haiku advisor (local mode only; needs Claude auth above) -----------------
# The local model calls the `ask_advisor` tool when it's stuck, and a turn that
# visibly stalls auto-escalates to Haiku with full tools. Without credentials the
# advisor silently stays out of the way.
# ASSISTANT_ADVISOR=1
# ASSISTANT_ADVISOR_MODEL=claude-haiku-4-5
# ASSISTANT_ADVISOR_RESCUE=1           # auto-escalate a stalled turn to the advisor
# ASSISTANT_ADVISOR_LOOP_LIMIT=3       # identical tool-call repeats before escalating

# --- Proactive engine ----------------------------------------------------------
# Every ~15 minutes (launchd job com.aide.proactive) Aide runs a registry of
# checks: due/stale tasks, a read-only email+calendar sweep (meeting prep,
# deadlines, important unanswered mail, bills, travel, commitments, conflicts),
# study summaries from recall, rabbit-hole synthesis, a weekly review, and a
# self/connector health check. Findings land silently in the Routines feed; only
# time-sensitive items ping, and never during quiet hours. Email/calendar are
# strictly read-only (Aide never organizes, labels, archives, or drafts in Gmail).
# Disable any single check with ASSISTANT_PROACTIVE_<NAME>=0, e.g.:
# ASSISTANT_PROACTIVE_STUDY=0
# ASSISTANT_PROACTIVE_SWEEP=0
# ASSISTANT_QUIET_START=23              # no pings from this hour ...
# ASSISTANT_QUIET_END=8                 # ... until this hour (feed still fills)
# Focus-aware silence: while one of these apps is frontmost, pings are held back
# (the item still lands in the feed and pings once you leave the app). Defaults
# cover meetings/shared-screen, presenting, and deep work. Comma-separated,
# case-insensitive substring match; set empty to disable.
# ASSISTANT_FOCUS_APPS=zoom.us,Zoom,Microsoft Teams,Webex,Keynote,Xcode,Terminal,iTerm2
# Idle RAM: the GUI releases its engine after this many idle minutes (0 = keep
# resident). It re-warms on your next message.
# ASSISTANT_IDLE_RELEASE_MIN=10

# --- Optional overrides ------------------------------------------------------
# ASSISTANT_NAME=Aide
# ASSISTANT_USER=                       # name the GUI greets you by (defaults to your macOS name)
# ASSISTANT_HOTKEY=0                    # 1 enables the ⌥Space hotkey (pynput can crash modern macOS)
# ASSISTANT_VIBRANCY=1                  # 0 forces the flat (non-translucent) sidebar
# ASSISTANT_RECALL=1                    # ambient recall on by default; 0 to disable
# ASSISTANT_RECALL_DAYS=30              # how long the screen-memory timeline is kept
# ASSISTANT_RECALL_MAX_MB=1500          # disk cap for stored screenshots (oldest pruned first)
# ASSISTANT_OBSERVE_SECONDS=5           # how often the observer samples the active window
# ASSISTANT_SHOT_SECONDS=10             # OCR-shot heartbeat; unchanged screens are discarded,
#                                       # so a fast cadence costs CPU, not disk
# ASSISTANT_SHOT_MIN_GAP=3              # min seconds between shots on rapid window switches
# ASSISTANT_DIGEST_MINUTES=30           # ambient understanding: every N minutes Haiku distills
#                                       # recent activity into "what you're working on" (0 = off)
# ASSISTANT_RECALL_EXCLUDE=             # extra apps/titles to never record, comma-separated
#                                       # (password managers, authenticators, and common
#                                       #  banking/finance contexts are excluded by default)
# Where the assistant keeps its memory, tasks, and briefings:
# ASSISTANT_HOME=~/.assistant
# Full system access (default on): assistant can act across your home directory
# without per-action approval. Set to 0 to sandbox it to ASSISTANT_HOME +
# ASSISTANT_ALLOWED_DIRS with edit confirmation.
# ASSISTANT_FULL_ACCESS=1
# Extra directories (colon-separated) when not in full-access mode:
# ASSISTANT_ALLOWED_DIRS=~/Documents:~/Projects
